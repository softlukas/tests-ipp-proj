+++ BUILT_IN_INTEGER
*** Test of arithmetic and comparison
!C! 0
!I! 0
>>> 1

class Main : Object {
  run [|
    sum := 0.
    block := [:x| 
      y := self p: x.
      sum := sum plus: x.
    ].

    x := 10 timesRepeat: block.
    x := -1 timesRepeat: block.
    y := self p: x.
    y := self p: sum.
  ]

  p: [:x|
    _ := (x asString) print.
  ]
}