class Main : Object {
  run [|
    a := Main.
    _ := self p: (a isNumber).

    a := Main.
    _ := self p: (a isString).

    a := Main.
    _ := self p: (a isBlock).

    a := Main.
    _ := self p: (a isNil).


  ]

  p: [:x|
    _ := (x asString) print.
  ]
}