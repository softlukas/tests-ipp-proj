+++ BUILT_IN_OBJECT
*** Test of built in function
!C! 0
!I! 0
>>> 1

"Nefunguje vyhladavanie built in v parentovy"

class Main : Object {
  run [|
    a := self.
    b := self.
    c := a identicalTo:b.
    _ := self p: c.

    a := Main new.
    b := Main new.
    c := a identicalTo:b.
    _ := self p: c.

    
  ]

  p: [:x|
    _ := (x asString) print.
  ]
}